{
  "id": "parallax-hero",
  "name": "Parallax Hero",
  "category": "Scroll",
  "engine": "gsap",
  "difficulty": "medium",
  "description": "Multi-layer parallax hero section where background, midground, and foreground elements move at different speeds creating depth on scroll.",
  "tags": ["parallax", "hero", "scroll", "depth", "layers", "gsap"],
  "defaultProps": {
    "headline": "BEYOND\nLIMITS",
    "subline": "Scroll to explore the depth",
    "bgColor": "#0a0a0f",
    "accentColor": "#00c3ff",
    "layerSpeed1": 0.3,
    "layerSpeed2": 0.6,
    "layerSpeed3": 0.9
  },
  "controls": [
    {
      "key": "headline",
      "label": "Headline Text",
      "type": "text",
      "default": "BEYOND\nLIMITS"
    },
    {
      "key": "subline",
      "label": "Subline Text",
      "type": "text",
      "default": "Scroll to explore the depth"
    },
    {
      "key": "accentColor",
      "label": "Accent Color",
      "type": "color",
      "default": "#00c3ff"
    },
    {
      "key": "bgColor",
      "label": "Background Color",
      "type": "color",
      "default": "#0a0a0f"
    },
    {
      "key": "layerSpeed1",
      "label": "Background Layer Speed",
      "type": "range",
      "min": 0.1,
      "max": 0.9,
      "step": 0.1,
      "default": 0.3
    },
    {
      "key": "layerSpeed2",
      "label": "Midground Layer Speed",
      "type": "range",
      "min": 0.1,
      "max": 0.9,
      "step": 0.1,
      "default": 0.6
    },
    {
      "key": "layerSpeed3",
      "label": "Foreground Layer Speed",
      "type": "range",
      "min": 0.1,
      "max": 1.2,
      "step": 0.1,
      "default": 0.9
    }
  ],
  "code": "// Parallax Hero with GSAP\ngsap.to('.layer-bg', {\n  yPercent: -30,\n  scrollTrigger: {\n    trigger: section,\n    scroller: wrapper,\n    start: 'top top',\n    end: 'bottom top',\n    scrub: true\n  }\n})\ngsap.to('.layer-mid', { yPercent: -60, scrub: true })\ngsap.to('.layer-fg', { yPercent: -90, scrub: true })",
  "animxSyntax": "animx.parallaxHero({\n  layers: ['.bg', '.mid', '.fg'],\n  speeds: [0.3, 0.6, 0.9]\n})"
}
